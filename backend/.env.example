# ── StreamSafe Backend Environment ──────────────────────────────────────────
# Copy this to .env and fill in your values

# App
APP_NAME=StreamSafe
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=CHANGE_ME_to_a_long_random_string_min_32_chars

# Database
# Render provides DATABASE_URL automatically when linked
# For local: postgresql://streamsafe:streamsafe@localhost:5432/streamsafe
DATABASE_URL=postgresql://streamsafe:streamsafe@localhost:5432/streamsafe

# Redis
# Render provides REDIS_URL automatically when linked
# For local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# CORS — add your Vercel frontend URL here
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# WebRTC STUN/TURN — free STUN works fine for demo
STUN_SERVER=stun:stun.l.google.com:19302
# Optional TURN server for production (coturn, Twilio, etc.)
TURN_SERVER=
TURN_USERNAME=
TURN_CREDENTIAL=

# S3 / File Storage — optional, leave blank for demo (files won't persist)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=streamsafe-recordings
S3_REGION=us-east-1
# For MinIO local: http://localhost:9000
S3_ENDPOINT_URL=
