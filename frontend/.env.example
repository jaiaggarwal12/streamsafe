# ── StreamSafe Frontend Environment ─────────────────────────────────────────
# Copy this to .env and fill in your values

# Your backend Render URL (no trailing slash)
VITE_API_URL=https://streamsafe-api.onrender.com

# WebSocket URL — same host, ws:// or wss://
VITE_WS_URL=wss://streamsafe-api.onrender.com

# For local development with docker-compose or direct:
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
